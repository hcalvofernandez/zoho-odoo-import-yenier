<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_zoho_import_log_list" model="ir.ui.view">
            <field name="name">zoho.import.log.list</field>
            <field name="model">zoho.import.log</field>
            <field name="arch" type="xml">
                <list string="Import Logs" decoration-success="state == 'done'" 
                      decoration-danger="state == 'error'" decoration-warning="state == 'partial'">
                    <field name="name"/>
                    <field name="create_date"/>
                    <field name="connector_id"/>
                    <field name="import_type"/>
                    <field name="state"/>
                    <field name="total_records"/>
                    <field name="imported_records"/>
                    <field name="updated_records"/>
                    <field name="failed_records"/>
                    <field name="duration_seconds" widget="float_time"/>
                </list>
            </field>
        </record>
        
        <record id="view_zoho_import_log_form" model="ir.ui.view">
            <field name="name">zoho.import.log.form</field>
            <field name="model">zoho.import.log</field>
            <field name="arch" type="xml">
                <form string="Import Log">
                    <header>
                        <button name="action_view_products" string="View Products" type="object"
                                invisible="not product_ids" class="btn-primary"/>
                        <button name="action_view_partners" string="View Partners" type="object"
                                invisible="not partner_ids" class="btn-primary"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="connector_id" readonly="1"/>
                                <field name="import_type" readonly="1"/>
                                <field name="state" readonly="1"/>
                            </group>
                            <group>
                                <field name="start_time" readonly="1"/>
                                <field name="end_time" readonly="1"/>
                                <field name="duration_seconds" readonly="1" widget="float_time"/>
                            </group>
                        </group>
                        <group string="Results">
                            <group>
                                <field name="total_records" readonly="1"/>
                                <field name="imported_records" readonly="1"/>
                                <field name="updated_records" readonly="1"/>
                            </group>
                            <group>
                                <field name="failed_records" readonly="1"/>
                                <field name="skipped_records" readonly="1"/>
                            </group>
                        </group>
                        <field name="error_details" readonly="1"/>
                        <field name="warning_details" readonly="1"/>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>
        
        <record id="action_zoho_import_log" model="ir.actions.act_window">
            <field name="name">Import Logs</field>
            <field name="res_model">zoho.import.log</field>
            <field name="view_mode">list,form</field>
            <field name="target">new</field>
            <field name="context">{}</field>
        </record>
    </data>
</odoo>
