<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_zoho_import_wizard_form" model="ir.ui.view">
            <field name="name">zoho.import.wizard.form</field>
            <field name="model">zoho.import.wizard</field>
            <field name="arch" type="xml">
                <form string="Import from Zoho">
                    <sheet>
                        <group>
                            <field name="connector_id"
                                   options="{'no_create': True, 'no_create_edit': True, 'no_quick_create': True}"/>
                        </group>
                        <group string="Select Data to Import">
                            <field name="import_products"/>
                            <field name="import_stock" invisible="not import_products"/>
                            <field name="import_partners"/>
                            <field name="partner_type" invisible="not import_partners"/>
                        </group>
                        <group string="Options">
                            <field name="update_existing"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_execute_import" string="Import Now" type="object"
                                class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
        
        <record id="action_zoho_import_wizard" model="ir.actions.act_window">
            <field name="name">Import from Zoho</field>
            <field name="res_model">zoho.import.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>
