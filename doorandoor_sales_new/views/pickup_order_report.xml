<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="report_pickup_order_document">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.external_layout">
                        <div class="page">
                            <h2>Orden de Recogida</h2>
                            <div class="row mt-3 mb-3">
                                <div class="col-6">
                                    <strong>Orden:</strong> <span t-field="o.name"/><br/>
                                    <strong>Factura:</strong> <span t-field="o.move_id.name"/><br/>
                                    <strong>Cliente:</strong> <span t-field="o.partner_id"/>
                                </div>
                                <div class="col-6 text-end">
                                    <strong>Almacen:</strong> <span t-field="o.warehouse_id"/><br/>
                                    <strong>Picking:</strong> <span t-field="o.picking_id"/><br/>
                                    <strong>Estado:</strong> <span t-field="o.state"/>
                                </div>
                            </div>
                            <div class="row mb-4 align-items-start">
                                <div class="col-8">
                                    <div>
                                        <strong>Codigo de documento</strong>
                                    </div>
                                    <div class="mt-2">
                                        <img t-att-src="o._ddsn_get_barcode_img_src()" alt="Pickup Barcode" style="max-width: 320px; max-height: 90px;"/>
                                    </div>
                                </div>
                                <div class="col-4 text-end">
                                    <div>
                                        <strong>Escanear para abrir</strong>
                                    </div>
                                    <div class="mt-2">
                                        <img t-att-src="o._ddsn_get_document_qr_img_src()" alt="Pickup QR" style="width: 110px; height: 110px;"/>
                                    </div>
                                </div>
                            </div>
                            <table class="table table-sm table-borderless o_main_table">
                                <thead>
                                    <tr>
                                        <th>Producto</th>
                                        <th class="text-end">Cantidad autorizada</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="o.pickup_line_ids" t-as="line">
                                        <td><span t-field="line.product_id"/></td>
                                        <td class="text-end"><span t-field="line.product_uom_qty"/></td>
                                    </tr>
                                </tbody>
                            </table>
                            <div class="row mt-4">
                                <div class="col-12">
                                    <strong>Notas:</strong>
                                    <div t-field="o.note"/>
                                </div>
                            </div>
                            <div class="row mt-5 pt-4">
                                <div class="col-6">
                                    <div style="margin-top: 30px;">
                                        <strong>Emitido por</strong>
                                    </div>
                                    <div style="border-top: 1px solid #000; margin-top: 45px; padding-top: 6px; min-height: 22px;">
                                        <span t-esc="o.create_uid.name"/>
                                    </div>
                                </div>
                                <div class="col-6 text-end">
                                    <div style="margin-top: 30px;">
                                        <strong>Recibido por</strong>
                                    </div>
                                    <div style="border-top: 1px solid #000; margin-top: 45px; padding-top: 6px; min-height: 22px;">
                                        &amp;nbsp;
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </template>

        <record id="action_report_pickup_order" model="ir.actions.report">
            <field name="name">Orden de Recogida</field>
            <field name="model">doorandoor.pickup.order</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">doorandoor_sales_new.report_pickup_order_document</field>
            <field name="report_file">doorandoor_sales_new.report_pickup_order_document</field>
            <field name="binding_model_id" ref="model_doorandoor_pickup_order"/>
            <field name="binding_type">report</field>
            <field name="print_report_name">'Orden de Recogida - %s' % (object.name)</field>
        </record>
    </data>
</odoo>
