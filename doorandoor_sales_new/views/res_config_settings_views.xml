<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_config_settings_view_form_inherit_doorandoor_sales_new" model="ir.ui.view">
            <field name="name">res.config.settings.form.doorandoor.sales.new</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form" position="inside">
                    <app string="DoorAndDoor Sales" name="doorandoor_sales_new">
                        <block title="Fulfillment Defaults">
                            <setting string="Payment Release Policy">
                                <field name="ddsn_payment_release_policy"/>
                            </setting>
                            <setting string="Fulfillment Route Policy">
                                <field name="ddsn_fulfillment_route_policy"/>
                            </setting>
                            <setting string="Partial Stock Policy">
                                <field name="ddsn_partial_stock_policy"/>
                            </setting>
                            <setting string="Picking Creation Policy">
                                <field name="ddsn_picking_creation_policy"/>
                            </setting>
                            <setting string="Manufacturing Creation Policy">
                                <field name="ddsn_mrp_creation_policy"/>
                            </setting>
                        </block>
                    </app>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
