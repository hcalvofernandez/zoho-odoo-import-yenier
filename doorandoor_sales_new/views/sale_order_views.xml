<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_order_form_inherit_ddsn_stock_visibility" model="ir.ui.view">
            <field name="name">sale.order.form.ddsn.stock.visibility</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="priority">100</field>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='order_line']/list/field[@name='product_uom_qty']" position="after">
                    <field name="ddsn_stock_display" string="Stock" readonly="1"/>
                    <field name="ddsn_warehouse_stock_display" string="Warehouses" readonly="1"/>
                    <field name="ddsn_warehouse_stock_html" string="Warehouses HTML" widget="html" optional="hide" readonly="1"/>
                    <field name="ddsn_bonus_percent" string="Bonus %" optional="show" readonly="1"/>
                    <field name="ddsn_bonus_source" string="Bonus Source" optional="hide" readonly="1"/>
                </xpath>
                <xpath expr="//field[@name='order_line']/form//field[@name='product_id']" position="after">
                    <group string="Stock Visibility" colspan="2">
                        <field name="ddsn_stock_display" readonly="1"/>
                        <field name="ddsn_warehouse_stock_text" readonly="1" widget="text"/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
