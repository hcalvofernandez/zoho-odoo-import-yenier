<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_doorandoor_fulfillment_line_tree" model="ir.ui.view">
            <field name="name">doorandoor.fulfillment.line.list</field>
            <field name="model">doorandoor.fulfillment.line</field>
            <field name="arch" type="xml">
                <list string="Fulfillment Lines">
                    <field name="move_id"/>
                    <field name="product_id"/>
                    <field name="amount_total"/>
                    <field name="amount_released"/>
                    <field name="picking_id"/>
                    <field name="mrp_production_id"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="view_doorandoor_fulfillment_line_form" model="ir.ui.view">
            <field name="name">doorandoor.fulfillment.line.form</field>
            <field name="model">doorandoor.fulfillment.line</field>
            <field name="arch" type="xml">
                <form string="Fulfillment Line">
                    <sheet>
                        <group>
                            <field name="move_id" readonly="1"/>
                            <field name="move_line_id" readonly="1"/>
                            <field name="sale_order_id" readonly="1"/>
                            <field name="sale_line_id" readonly="1"/>
                            <field name="product_id" readonly="1"/>
                            <field name="picking_id" readonly="1"/>
                            <field name="mrp_production_id" readonly="1"/>
                            <field name="state" readonly="1"/>
                        </group>
                        <group>
                            <field name="amount_total" readonly="1"/>
                            <field name="amount_released" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_doorandoor_fulfillment_line" model="ir.actions.act_window">
            <field name="name">Fulfillment Lines</field>
            <field name="res_model">doorandoor.fulfillment.line</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
