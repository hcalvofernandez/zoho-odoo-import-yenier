<?xml version="1.0" encoding="utf-8"?>
<!--
    DoorAndDoor - Botón de Entrega desde Ventas
    Vistas heredadas de stock.picking
-->
<odoo>
    <data>

        <!-- ============================================================ -->
        <!-- HERENCIA: Formulario de Picking (stock.view_picking_form) -->
        <!-- ============================================================ -->
        <record id="view_picking_form_inherit_sale_id" model="ir.ui.view">
            <field name="name">stock.picking.form.sale.id</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="priority">99</field>
            <field name="arch" type="xml">
                <!-- Agregar campo sale_id después del campo origin -->
                <xpath expr="//field[@name='origin']" position="after">
                    <field name="sale_id" 
                           readonly="1"
                           options="{'no_create': True}"
                           invisible="not sale_id"/>
                </xpath>
            </field>
        </record>

        <!-- ============================================================ -->
        <!-- HERENCIA: Vista Tree de Pickings (stock.vpicktree) -->
        <!-- ============================================================ -->
        <record id="view_picking_tree_inherit_sale_id" model="ir.ui.view">
            <field name="name">stock.picking.tree.sale.id</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.vpicktree"/>
            <field name="priority">99</field>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='origin']" position="after">
                    <field name="sale_id" optional="hide"/>
                </xpath>
            </field>
        </record>

        <!-- ============================================================ -->
        <!-- HERENCIA: Filtros de búsqueda (stock.view_picking_internal_search) -->
        <!-- ============================================================ -->
        <record id="view_picking_search_inherit_sale_id" model="ir.ui.view">
            <field name="name">stock.picking.search.sale.id</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_internal_search"/>
            <field name="priority">99</field>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='origin']" position="after">
                    <field name="sale_id" string="Pedido de Venta"/>
                </xpath>
                <xpath expr="//filter[@name='activities_exception']" position="after">
                    <separator/>
                    <filter string="Con Venta Relacionada" name="with_sale_order" domain="[('sale_id', '!=', False)]"/>
                    <filter string="Sin Venta Relacionada" name="without_sale_order" domain="[('sale_id', '=', False)]"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
