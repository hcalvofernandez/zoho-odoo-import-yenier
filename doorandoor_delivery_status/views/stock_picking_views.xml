<?xml version="1.0" encoding="utf-8"?>
<!--
    DoorAndDoor - Estado de Entrega en Picking
    Vistas heredadas de stock.picking y stock.move

    CORRECCIÓN Odoo 18 - Versión 1.0.6:
    - No todas las bases Odoo 18 exponen el XML ID stock.view_move_picking_tree
    - La grilla principal ya se cubre desde stock_move_views.xml con vistas stock.move estables
    - Aquí heredamos solo la vista de operaciones detalladas
-->
<odoo>
    <data>

        <!-- ============================================================ -->
        <!-- HERENCIA: Vista Tree de Operaciones Detalladas                 -->
        <!-- (stock.view_stock_move_line_detailed_operation_tree)           -->
        <!-- ============================================================ -->
        <record id="view_stock_move_line_detailed_tree_inherit" model="ir.ui.view">
            <field name="name">stock.move.line.operations.tree.delivery.status</field>
            <field name="model">stock.move.line</field>
            <field name="inherit_id" ref="stock.view_stock_move_line_detailed_operation_tree"/>
            <field name="priority">99</field>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='product_id']" position="after">
                    <field name="move_id" invisible="1"/>
                    <field name="qty_ordered" 
                           optional="hide"
                           readonly="1"/>
                    <field name="qty_delivered_this" 
                           optional="hide"
                           readonly="1"/>
                    <field name="qty_pending" 
                           optional="hide"
                           readonly="1"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
